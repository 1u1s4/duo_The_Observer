# Cuenta de TikTok a observar (sin @)
TIKTOK_USER=rtvenoticias

# Directorio base para salidas (logs y archivos legacy)
OBSERVER_OUTPUT_DIR=./output

# Nivel de logging global: DEBUG, INFO, WARNING, ERROR
OBSERVER_LOG_LEVEL=INFO

# Timeout recomendado para operaciones de conexion en segundos
OBSERVER_CONNECT_TIMEOUT=15

# Retraso recomendado entre reintentos en segundos
OBSERVER_RETRY_SECONDS=10
